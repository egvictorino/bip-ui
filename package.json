{
  "name": "bip-ui",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "description": "BipUI — React component library and design system",
  "scripts": {
    "dev": "pnpm --parallel --recursive dev",
    "build": "pnpm --recursive build",
    "test": "echo \"Tests pendientes\"",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.15.9"
  },
  "pnpm": {
    "overrides": {
      "storybook": "^8.6.17",
      "@storybook/addon-essentials": "^8.6.17",
      "@storybook/addon-interactions": "^8.6.17",
      "@storybook/addon-links": "^8.6.17",
      "@storybook/blocks": "^8.6.17",
      "@storybook/react": "^8.6.17",
      "@storybook/react-vite": "^8.6.17",
      "@storybook/test": "^8.6.17",
      "esbuild": "^0.25.0",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup": "^4.59.0"
    }
  }
}